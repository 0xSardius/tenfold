# Tenfold — environment variable template
# Copy this file to .env.local and fill in real values. .env.local is gitignored.
# Never commit real secrets. Names here match the Neynar/Farcaster scaffold and our stack.

# --- Database: Neon Postgres (milestone 1) ---
# Pooled connection string from the Neon dashboard (used by the app at runtime).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"
# Direct (unpooled) connection — used by Drizzle Kit for migrations.
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# --- Neynar / Farcaster (milestone 1 + 6) ---
# Server-side Neynar API key (from https://dev.neynar.com). NEVER expose client-side.
NEYNAR_API_KEY=""
# Public Neynar client ID for Sign In With Neynar (SIWN). Safe to expose (NEXT_PUBLIC_).
# Remember to add localhost + your prod domain to the app's Authorized Origins in Neynar.
NEXT_PUBLIC_NEYNAR_CLIENT_ID=""

# --- App URL ---
# Public base URL of the app. Used by the mini-app manifest, embeds, and notifications.
# Local: http://localhost:3000   Prod: https://your-domain.vercel.app
NEXT_PUBLIC_URL="http://localhost:3000"

# --- AI coach: Anthropic Claude API (milestone 3 — not needed yet) ---
# Server-side only. Leave blank until milestone 3.
ANTHROPIC_API_KEY=""

# --- Farcaster manifest account association (milestone 6) ---
# Generated by the Neynar scaffold / farcaster.json signing flow. Leave blank until then.
FARCASTER_HEADER=""
FARCASTER_PAYLOAD=""
FARCASTER_SIGNATURE=""
